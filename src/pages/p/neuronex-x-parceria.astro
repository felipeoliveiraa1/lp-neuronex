    <script>
      // Proteção de link por token
      (function () {
        const expected = document.body.getAttribute('data-token');
        const params = new URLSearchParams(window.location.search);
        const got = params.get('t');
        if (expected && got !== expected) {
          // Redireciona pra home se token inválido/ausente
          // Comente a linha abaixo se quiser deixar página pública
          // window.location.href = '/';
        }
      })();

      // Animação de contadores
      const counters = document.querySelectorAll('[data-count]');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const target = parseInt(el.getAttribute('data-count') || '0');
              const original = el.textContent;
              let current = 0;
              const step = Math.max(1, Math.floor(target / 40));
              const tick = () => {
                current = Math.min(current + step, target);
                el.textContent = original.replace(/\d+/, current.toString());
                if (current < target) requestAnimationFrame(tick);
                else el.textContent = original;
              };
              tick();
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.4 }
      );
      counters.forEach((c) => observer.observe(c));

      // Calculadora ROI
      const $ = (sel) => document.getElementById(sel);
      const alunos = 150;
      const custoMes = 825;

      function formatBRL(v) {
        return v.toLocaleString('pt-BR', {
          style: 'currency',
          currency: 'BRL',
          maximumFractionDigits: 0,
        });
      }

      function updateCalc() {
        const conv = parseInt($('conv').value);
        const ticket = parseInt($('ticket').value);
        const meses = parseInt($('meses').value);

        const clientes = Math.round((alunos * conv) / 100);
        const mrr = clientes * ticket;
        const lucroMes = Math.max(0, mrr - custoMes);
        const total = lucroMes * meses;
        const neuronex = total * 0.3;
        const socio = total * 0.35;

        $('out-conversao').textContent = conv + '%';
        $('out-ticket').textContent = formatBRL(ticket);
        $('out-meses').textContent = meses + ' meses';
        $('out-clientes').textContent = clientes;
        $('out-mrr').textContent = formatBRL(mrr);
        $('out-lucro').textContent = formatBRL(lucroMes);
        $('out-total').textContent = formatBRL(total);
        $('out-neuronex').textContent = formatBRL(neuronex);
        $('out-socio').textContent = formatBRL(socio);
      }

      ['conv', 'ticket', 'meses'].forEach((id) => {
        const el = $(id);
        if (el) el.addEventListener('input', updateCalc);
      });
      updateCalc();
    </script>

