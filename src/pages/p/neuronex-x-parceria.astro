---
// NEURONEX — Proposta de Parceria Estratégica
// Rota: /p/neuronex-x-parceria
// Acesso protegido via ?t=TOKEN

import '../../styles/fonts.css';
import '../../styles/css-custom-properties.css';
import '../../styles/reset-base.css';
import '../../styles/typography.css';

// CUSTOMIZE: dados da proposta
const proposta = {
  cliente: {
    nome: 'Sócios',
    curso: 'Curso de Amazon',
    alunos: 150,
  },
  whatsapp: '5511968141852',
  token: 'af2026',
  prazo: '4 a 6 semanas',
};

const whatsappMsg = encodeURIComponent(
  'Olá! Li a proposta da NeuroNex e gostaria de conversar.',
);
const whatsappUrl = `https://wa.me/${proposta.whatsapp}?text=${whatsappMsg}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>NeuroNex — Proposta de Parceria</title>
    <meta
      name="description"
      content="Proposta estratégica de parceria NeuroNex para a construção de uma plataforma sob medida."
    />
    <meta name="theme-color" content="#060610" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body data-token={proposta.token}>
    <!-- NAV -->
    <header class="nav">
      <a class="nav-logo" href="/" aria-label="NeuroNex">
        <img src="/logo-nav.webp" alt="NeuroNex" width="120" height="32" />
      </a>
      <span class="nav-badge">Proposta confidencial</span>
    </header>

    <!-- 01 · HERO -->
    <section class="hero">
      <div class="container">
        <span class="eyebrow">Parceria estratégica</span>
        <h1>
          Uma ideia que merece<br />
          <span class="accent">virar produto.</span>
        </h1>
        <p class="lead">
          Vocês têm a audiência, a expertise e o mercado.
          A NeuroNex traz a tecnologia sob medida pra transformar
          isso numa plataforma que escala — e gera receita recorrente.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#produto">Ver o que vamos construir</a>
          <a class="btn btn-ghost" href="#acordo">Ir direto pra proposta</a>
        </div>
      </div>
      <div class="hero-glow" aria-hidden="true"></div>
    </section>

    <!-- 02 · CONTEXTO -->
    <section class="section">
      <div class="container">
        <div class="grid-2">
          <div>
            <span class="section-label">Contexto</span>
            <h2>O cenário</h2>
          </div>
          <div class="context-body">
            <p>
              Vocês conduzem um curso consolidado sobre venda na Amazon
              com <strong>{proposta.alunos} alunos ativos</strong>.
              Hoje eles pagam por ferramentas de análise
              estrangeiras — caras, em inglês e desenhadas pra outro perfil.
            </p>
            <p>
              A oportunidade é clara: entregar, dentro do próprio ecossistema,
              uma ferramenta proprietária que aumenta a retenção,
              abre um novo canal de receita recorrente e reforça a marca
              como autoridade técnica no mercado.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 03 · O QUE VAMOS CONSTRUIR -->
    <section id="produto" class="section dark">
      <div class="container">
        <span class="section-label">O produto</span>
        <h2>Uma extensão que analisa qualquer produto<br />da Amazon em tempo real.</h2>
        <p class="section-lead">
          Uma camada inteligente que aparece sobre o site da Amazon e entrega,
          em segundos, margem, ROI, projeção de vendas e risco — tudo em português,
          com UI pensada pra quem vive do negócio.
        </p>

        <div class="feature-grid">
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
            </div>
            <h3>Análise instantânea</h3>
            <p>Histórico de preços, BSR e vendedores direto no layout da Amazon.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg>
            </div>
            <h3>Calculadora de lucro</h3>
            <p>Margem real, ROI e projeção de vendas com cenários conservador e otimista.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            </div>
            <h3>Assistente de IA</h3>
            <p>Orientação contextual sobre oportunidade, risco e estratégia de precificação.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M4 10h16M10 4v16"/></svg>
            </div>
            <h3>Dashboard proprietário</h3>
            <p>Painel para vocês acompanharem uso, assinaturas e métricas dos alunos.</p>
          </div>
        </div>

        <!-- Preview / demo iframe placeholder -->
        <div class="preview-frame">
          <div class="preview-header">
            <span class="preview-dot red"></span>
            <span class="preview-dot yellow"></span>
            <span class="preview-dot green"></span>
            <span class="preview-url">amazon.com.br/dp/B08XXXXXXX</span>
          </div>
          <div class="preview-body">
            <div class="preview-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <p>Demo da extensão em funcionamento</p>
              <small>Vídeo ou iframe será inserido aqui</small>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04 · MÉTODO -->
    <section class="section">
      <div class="container">
        <span class="section-label">Como construímos</span>
        <h2>O método NeuroNex, em quatro etapas.</h2>

        <div class="steps">
          <div class="step">
            <span class="step-num">01</span>
            <h3>Diagnóstico</h3>
            <p>Mapeamos o fluxo dos alunos, fontes de dados e métricas críticas.</p>
          </div>
          <div class="step">
            <span class="step-num">02</span>
            <h3>Design & arquitetura</h3>
            <p>Desenhamos UI, stack e integrações antes de escrever código.</p>
          </div>
          <div class="step">
            <span class="step-num">03</span>
            <h3>Construção</h3>
            <p>Entregas semanais com ambiente de homologação desde a semana 2.</p>
          </div>
          <div class="step">
            <span class="step-num">04</span>
            <h3>Lançamento & evolução</h3>
            <p>Go-live na Chrome Web Store + roadmap contínuo baseado em dados de uso.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 05 · STACK -->
    <section class="section muted">
      <div class="container">
        <span class="section-label">Stack</span>
        <h2>Tecnologia testada, sem apostas.</h2>
        <div class="stack-grid">
          <div class="stack-col">
            <h4>Frontend</h4>
            <ul>
              <li>React 18 · TypeScript</li>
              <li>Chrome Extension MV3</li>
              <li>Tailwind + Shadow DOM</li>
            </ul>
          </div>
          <div class="stack-col">
            <h4>Backend</h4>
            <ul>
              <li>NestJS · TypeScript</li>
              <li>Prisma · PostgreSQL</li>
              <li>Redis · BullMQ</li>
            </ul>
          </div>
          <div class="stack-col">
            <h4>Dados</h4>
            <ul>
              <li>Keepa API</li>
              <li>OpenAI / Claude</li>
              <li>Scraping controlado</li>
            </ul>
          </div>
          <div class="stack-col">
            <h4>Infra</h4>
            <ul>
              <li>Railway · Vercel</li>
              <li>Neon · Upstash</li>
              <li>Cloudflare · Chrome Store</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 06 · CRONOGRAMA -->
    <section class="section">
      <div class="container">
        <span class="section-label">Cronograma</span>
        <h2>Do briefing ao lançamento em {proposta.prazo}.</h2>

        <div class="timeline">
          <div class="tl-item">
            <span class="tl-week">Semana 1</span>
            <h4>Kickoff</h4>
            <p>Fechamento de escopo, acesso aos dados e wireframes iniciais.</p>
          </div>
          <div class="tl-item">
            <span class="tl-week">Semana 2–3</span>
            <h4>Core</h4>
            <p>Extensão funcional em ambiente de testes — primeiras análises reais.</p>
          </div>
          <div class="tl-item">
            <span class="tl-week">Semana 4–5</span>
            <h4>Integrações & IA</h4>
            <p>Keepa, OpenAI, autenticação e painel administrativo.</p>
          </div>
          <div class="tl-item">
            <span class="tl-week">Semana 6</span>
            <h4>Go-live</h4>
            <p>Publicação na Chrome Web Store e ativação pros alunos.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 07 · ESCOPO -->
    <section class="section dark">
      <div class="container">
        <span class="section-label">Escopo</span>
        <h2>O que entra. E o que não entra.</h2>

        <div class="scope-grid">
          <div class="scope-col in">
            <h4>Incluído na parceria</h4>
            <ul>
              <li>Extensão Chrome completa e publicada</li>
              <li>Backend, banco e infraestrutura</li>
              <li>Painel administrativo para os sócios</li>
              <li>Integração com Keepa e IA</li>
              <li>Autenticação e controle de acesso</li>
              <li>Correções de bugs e manutenção da base</li>
              <li>Suporte técnico direto via WhatsApp</li>
              <li>Hospedagem e monitoramento contínuos</li>
            </ul>
          </div>
          <div class="scope-col out">
            <h4>Não incluído</h4>
            <ul>
              <li>Novas features grandes pós-lançamento</li>
              <li>Versão mobile ou app nativo</li>
              <li>Integrações com novos marketplaces</li>
              <li>Campanhas de marketing e tráfego pago</li>
              <li>Atendimento direto aos alunos finais</li>
              <li>Custos de APIs externas (Keepa, OpenAI)</li>
            </ul>
            <p class="scope-note">
              Novas features grandes são orçadas à parte como projetos separados.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 08 · A PROPOSTA (valor aparece aqui) -->
    <section id="acordo" class="section proposal">
      <div class="container">
        <span class="section-label">A proposta</span>
        <h2>Um modelo que protege<br />os dois lados.</h2>
        <p class="section-lead">
          Não é trabalho por hora. É uma parceria com pele em jogo,
          onde o sucesso da plataforma é sucesso dos três.
        </p>

        <div class="deal-grid">
          <div class="deal-card main">
            <span class="deal-tag">Aporte de construção</span>
            <div class="deal-value">R$ 10.000</div>
            <p>
              Valor único pra cobrir os custos diretos do desenvolvimento inicial.
              Pago em duas parcelas: 50% no kickoff, 50% na entrega.
            </p>
          </div>

          <div class="deal-card main">
            <span class="deal-tag">Participação societária</span>
            <div class="deal-value">30<span>%</span></div>
            <p>
              NeuroNex entra como sócia da operação da ferramenta,
              com vesting de 24 meses e prorata em novas rodadas.
            </p>
          </div>

          <div class="deal-card main">
            <span class="deal-tag">Pró-labore mensal</span>
            <div class="deal-value">R$ 2.500<span>/mês</span></div>
            <p>
              A partir do mês 2 de operação. Garante manutenção ativa,
              correções, hospedagem e suporte técnico dedicado.
            </p>
          </div>
        </div>

        <div class="deal-footer">
          <div>
            <strong>Por que assim?</strong>
            <p>
              Desenvolver uma plataforma do zero tem custo de mercado entre R$ 60k e R$ 120k.
              Ao aceitar 1/6 do valor em aporte e entrar como sócia,
              a NeuroNex sinaliza confiança de longo prazo.
              O pró-labore mensal protege a continuidade técnica — sem ele,
              a plataforma vira um ativo abandonado em 6 meses.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 09 · WIN-WIN -->
    <section class="section">
      <div class="container">
        <span class="section-label">Win-win</span>
        <h2>Por que faz sentido pros dois lados.</h2>

        <div class="ww-grid">
          <div class="ww-col">
            <h4>Para os sócios</h4>
            <ul>
              <li>Aporte 6× menor do que construir isolado</li>
              <li>Time técnico sênior sem contratar CTO</li>
              <li>Ferramenta exclusiva como diferencial do curso</li>
              <li>Nova fonte de receita recorrente</li>
              <li>Retenção e LTV dos alunos mais altos</li>
            </ul>
          </div>
          <div class="ww-col">
            <h4>Para a NeuroNex</h4>
            <ul>
              <li>Case real em mercado validado</li>
              <li>Participação de longo prazo no upside</li>
              <li>Produto próprio no portfólio</li>
              <li>Distribuição imediata para 150 alunos</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 10 · CLÁUSULAS -->
    <section class="section muted">
      <div class="container">
        <span class="section-label">Cláusulas essenciais</span>
        <h2>O que fica registrado no contrato.</h2>

        <div class="clauses">
          <div class="clause">
            <span class="clause-num">01</span>
            <p><strong>Vesting de 24 meses</strong> com cliff de 6 meses sobre os 30%.</p>
          </div>
          <div class="clause">
            <span class="clause-num">02</span>
            <p><strong>Propriedade do código</strong> da operação da plataforma, com licença de uso pra NeuroNex.</p>
          </div>
          <div class="clause">
            <span class="clause-num">03</span>
            <p><strong>Direito prorata</strong> em novas rodadas de investimento ou entrada de sócios.</p>
          </div>
          <div class="clause">
            <span class="clause-num">04</span>
            <p><strong>NDA mútuo</strong> protegendo dados dos alunos e código-fonte.</p>
          </div>
          <div class="clause">
            <span class="clause-num">05</span>
            <p><strong>Reajuste anual</strong> do pró-labore pelo IPCA.</p>
          </div>
          <div class="clause">
            <span class="clause-num">06</span>
            <p><strong>Saída planejada</strong> com 90 dias de aviso prévio e handover técnico documentado.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 11 · CTA FINAL -->
    <section class="section cta-final">
      <div class="container center">
        <span class="section-label">Próximo passo</span>
        <h2>Se fizer sentido pros dois lados,<br />a gente começa semana que vem.</h2>
        <p class="section-lead">
          Me chame no WhatsApp. Em 30 minutos alinhamos detalhes,
          ajustamos o que precisar e assinamos o contrato.
        </p>
        <div class="hero-actions center">
          <a class="btn btn-primary lg" href={whatsappUrl} target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.6-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.6-.7 1.9-1.3.2-.6.2-1.2.2-1.3 0-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.4 1.3 4.8L2 22l5.4-1.3C8.7 21.5 10.3 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
            Conversar no WhatsApp
          </a>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container center">
        <img src="/logo-nav.webp" alt="NeuroNex" height="28" />
        <p>Proposta confidencial · NeuroNex · {new Date().getFullYear()}</p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const expected = document.body.getAttribute('data-token');
        const params = new URLSearchParams(window.location.search);
        const got = params.get('t');
        if (expected && got !== expected) {
          document.body.innerHTML =
            '<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#060610;color:#E8E8ED;font-family:Inter,sans-serif;padding:24px;text-align:center"><div><p style="opacity:.6;margin-bottom:8px">Proposta confidencial</p><h1 style="font-family:Outfit,sans-serif;font-weight:300;font-size:2rem;margin-bottom:16px">Link inválido ou expirado</h1><a href="https://www.neuronex.digital" style="color:#a78bfa;text-decoration:none">Ir para neuronex.digital →</a></div></div>';
        }
      })();
    </script>

    <style is:global>
      body {
        background: var(--bg-0);
        color: var(--text);
        font-family: var(--font-body);
        font-weight: 300;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      ::selection { background: var(--accent); color: #fff; }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 32px;
      }

      /* NAV */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        height: 64px;
        padding: 0 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(6,6,16,0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(124,58,237,0.1);
      }
      .nav-logo img {
        height: 30px;
        width: auto;
        display: block;
      }
      .nav-badge {
        font-size: 0.72rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 6px 14px;
        border: 1px solid var(--border-m);
        border-radius: 999px;
        background: rgba(124,58,237,0.05);
      }

      /* HERO */
      .hero {
        position: relative;
        padding: 180px 0 120px;
        text-align: center;
        overflow: hidden;
      }
      .hero-glow {
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(ellipse at center, rgba(124,58,237,0.25), transparent 60%);
        filter: blur(40px);
        pointer-events: none;
        z-index: 0;
      }
      .hero .container { position: relative; z-index: 1; }
      .eyebrow,
      .section-label {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-light);
        padding: 6px 14px;
        border: 1px solid var(--border-m);
        border-radius: 999px;
        background: rgba(124,58,237,0.06);
        margin-bottom: 28px;
      }
      .hero h1 {
        font-family: var(--font-head);
        font-weight: 200;
        font-size: clamp(2.4rem, 6vw, 4.2rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
        color: var(--heading);
        margin-bottom: 28px;
      }
      .accent {
        background: linear-gradient(135deg, var(--accent-light), var(--accent));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .lead,
      .section-lead {
        font-size: 1.05rem;
        font-weight: 300;
        color: var(--text);
        opacity: 0.75;
        max-width: 620px;
        margin: 0 auto 36px;
      }
      .hero-actions {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .hero-actions.center { justify-content: center; }

      /* BUTTONS */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        border-radius: 999px;
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 400;
        cursor: pointer;
        transition: all 0.25s var(--ease-out);
        text-decoration: none;
      }
      .btn.lg { padding: 16px 32px; font-size: 1rem; }
      .btn-primary {
        background: linear-gradient(135deg, var(--accent-dark), var(--accent));
        color: #fff;
        border: none;
        box-shadow: 0 0 20px rgba(124,58,237,0.3);
      }
      .btn-primary:hover {
        box-shadow: 0 0 36px rgba(124,58,237,0.5);
        transform: translateY(-1px);
      }
      .btn-ghost {
        background: transparent;
        border: 1px solid var(--border-m);
        color: var(--text);
      }
      .btn-ghost:hover {
        border-color: var(--accent);
        color: var(--accent-light);
        box-shadow: 0 0 18px rgba(124,58,237,0.2);
      }

      /* SECTIONS */
      .section {
        padding: 96px 0;
        position: relative;
      }
      .section.dark { background: var(--bg-1); }
      .section.muted {
        background: linear-gradient(180deg, var(--bg-0), var(--bg-1));
      }
      .section h2 {
        font-family: var(--font-head);
        font-weight: 200;
        font-size: clamp(1.9rem, 4vw, 3rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--heading);
        margin-bottom: 20px;
      }
      .section h3 {
        font-family: var(--font-head);
        font-weight: 300;
        font-size: 1.15rem;
        color: var(--heading);
        margin-bottom: 8px;
      }
      .section h4 {
        font-family: var(--font-head);
        font-weight: 400;
        font-size: 0.85rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--accent-light);
        margin-bottom: 16px;
      }
      .center { text-align: center; }

      /* GRID 2 */
      .grid-2 {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 60px;
        align-items: start;
      }
      @media (max-width: 720px) {
        .grid-2 { grid-template-columns: 1fr; gap: 24px; }
      }
      .context-body p {
        margin-bottom: 18px;
        font-size: 1rem;
        opacity: 0.85;
      }
      .context-body strong {
        color: var(--heading);
        font-weight: 500;
      }

      /* FEATURE GRID */
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 48px;
      }
      .feature {
        padding: 28px 24px;
        border: 1px solid var(--border-s);
        border-radius: 18px;
        background: var(--glass);
        transition: all 0.3s var(--ease-out);
      }
      .feature:hover {
        border-color: var(--border-m);
        transform: translateY(-2px);
        box-shadow: var(--glow-sm);
      }
      .feature-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(124,58,237,0.2), rgba(124,58,237,0.05));
        border: 1px solid var(--border-m);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-light);
        margin-bottom: 18px;
      }
      .feature p {
        font-size: 0.9rem;
        opacity: 0.7;
      }

      /* PREVIEW FRAME */
      .preview-frame {
        margin-top: 56px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border-m);
        background: var(--bg-2);
        box-shadow: 0 20px 60px rgba(0,0,0,0.5), var(--glow-md);
      }
      .preview-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: var(--bg-1);
        border-bottom: 1px solid var(--border-s);
      }
      .preview-dot {
        width: 10px; height: 10px; border-radius: 50%;
      }
      .preview-dot.red { background: #ff5f57; }
      .preview-dot.yellow { background: #febc2e; }
      .preview-dot.green { background: #28c840; }
      .preview-url {
        margin-left: 16px;
        font-size: 0.75rem;
        color: var(--muted);
        font-family: 'Inter', monospace;
      }
      .preview-body {
        aspect-ratio: 16 / 9;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .preview-placeholder {
        text-align: center;
        color: var(--muted);
      }
      .preview-placeholder svg {
        color: var(--accent);
        margin-bottom: 16px;
      }
      .preview-placeholder p {
        font-size: 1rem;
        color: var(--text);
        margin-bottom: 4px;
      }
      .preview-placeholder small {
        font-size: 0.78rem;
        opacity: 0.5;
      }

      /* STEPS */
      .steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 48px;
      }
      .step {
        padding: 28px 24px;
        border: 1px solid var(--border-s);
        border-radius: 18px;
        background: var(--glass);
      }
      .step-num {
        font-family: var(--font-head);
        font-size: 2rem;
        font-weight: 200;
        color: var(--accent);
        opacity: 0.6;
        display: block;
        margin-bottom: 12px;
      }
      .step p {
        font-size: 0.9rem;
        opacity: 0.7;
      }

      /* STACK */
      .stack-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 24px;
        margin-top: 48px;
      }
      .stack-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .stack-col li {
        font-size: 0.9rem;
        padding: 8px 0;
        border-bottom: 1px solid var(--border-s);
        opacity: 0.8;
      }
      .stack-col li:last-child { border-bottom: none; }

      /* TIMELINE */
      .timeline {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0;
        margin-top: 48px;
        position: relative;
      }
      .tl-item {
        padding: 24px;
        border: 1px solid var(--border-s);
        border-radius: 14px;
        background: var(--glass);
        margin: 4px;
      }
      .tl-week {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent-light);
        display: block;
        margin-bottom: 10px;
      }
      .tl-item h4 {
        font-family: var(--font-head);
        font-weight: 300;
        font-size: 1.05rem;
        color: var(--heading);
        text-transform: none;
        letter-spacing: 0;
        margin-bottom: 8px;
      }
      .tl-item p {
        font-size: 0.88rem;
        opacity: 0.7;
      }

      /* SCOPE */
      .scope-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-top: 48px;
      }
      @media (max-width: 720px) {
        .scope-grid { grid-template-columns: 1fr; }
      }
      .scope-col {
        padding: 32px;
        border-radius: 18px;
        border: 1px solid var(--border-s);
        background: var(--glass);
      }
      .scope-col.in { border-color: rgba(124,58,237,0.3); }
      .scope-col ul {
        list-style: none;
        padding: 0;
      }
      .scope-col li {
        padding: 10px 0 10px 28px;
        font-size: 0.92rem;
        position: relative;
        border-bottom: 1px solid var(--border-s);
      }
      .scope-col li:last-child { border-bottom: none; }
      .scope-col.in li::before {
        content: '';
        position: absolute;
        left: 0; top: 14px;
        width: 16px; height: 16px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent-dark), var(--accent));
        box-shadow: 0 0 10px rgba(124,58,237,0.5);
      }
      .scope-col.in li::after {
        content: '';
        position: absolute;
        left: 5px; top: 18px;
        width: 6px; height: 3px;
        border-left: 1.5px solid #fff;
        border-bottom: 1.5px solid #fff;
        transform: rotate(-45deg);
      }
      .scope-col.out li::before {
        content: '×';
        position: absolute;
        left: 4px; top: 8px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1;
      }
      .scope-note {
        margin-top: 20px;
        padding: 14px 16px;
        background: rgba(124,58,237,0.05);
        border: 1px solid var(--border-s);
        border-radius: 10px;
        font-size: 0.82rem;
        color: var(--muted);
      }

      /* PROPOSAL */
      .section.proposal {
        background:
          radial-gradient(ellipse at top, rgba(124,58,237,0.15), transparent 60%),
          var(--bg-1);
        text-align: center;
      }
      .deal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-top: 48px;
      }
      .deal-card {
        padding: 40px 28px;
        border-radius: 20px;
        border: 1px solid var(--border-m);
        background: linear-gradient(180deg, var(--bg-2), var(--bg-1));
        text-align: left;
        transition: all 0.3s var(--ease-out);
      }
      .deal-card:hover {
        border-color: var(--accent);
        box-shadow: var(--glow-md);
      }
      .deal-tag {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-light);
        margin-bottom: 18px;
      }
      .deal-value {
        font-family: var(--font-head);
        font-weight: 200;
        font-size: 2.8rem;
        line-height: 1;
        color: var(--heading);
        margin-bottom: 18px;
        letter-spacing: -0.02em;
      }
      .deal-value span {
        font-size: 1.4rem;
        color: var(--muted);
        font-weight: 300;
      }
      .deal-card p {
        font-size: 0.88rem;
        opacity: 0.75;
      }
      .deal-footer {
        margin-top: 56px;
        padding: 32px;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
        border: 1px solid var(--border-s);
        border-radius: 16px;
        background: var(--glass);
        text-align: left;
      }
      .deal-footer strong {
        display: block;
        color: var(--accent-light);
        margin-bottom: 10px;
        font-weight: 400;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .deal-footer p {
        font-size: 0.92rem;
        opacity: 0.8;
      }

      /* WIN-WIN */
      .ww-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-top: 48px;
      }
      @media (max-width: 720px) {
        .ww-grid { grid-template-columns: 1fr; }
      }
      .ww-col {
        padding: 32px;
        border: 1px solid var(--border-s);
        border-radius: 18px;
        background: var(--glass);
      }
      .ww-col ul {
        list-style: none;
        padding: 0;
      }
      .ww-col li {
        padding: 10px 0 10px 22px;
        font-size: 0.92rem;
        position: relative;
        border-bottom: 1px solid var(--border-s);
      }
      .ww-col li:last-child { border-bottom: none; }
      .ww-col li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--accent);
      }

      /* CLAUSES */
      .clauses {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
        margin-top: 48px;
      }
      .clause {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        padding: 20px;
        border: 1px solid var(--border-s);
        border-radius: 12px;
        background: var(--glass);
      }
      .clause-num {
        font-family: var(--font-head);
        font-weight: 300;
        font-size: 1.1rem;
        color: var(--accent);
        opacity: 0.6;
        flex-shrink: 0;
      }
      .clause p {
        font-size: 0.88rem;
        opacity: 0.85;
        line-height: 1.55;
      }
      .clause strong {
        color: var(--heading);
        font-weight: 500;
      }

      /* CTA FINAL */
      .section.cta-final {
        padding: 140px 0;
        background:
          radial-gradient(ellipse at center, rgba(124,58,237,0.2), transparent 60%),
          var(--bg-0);
      }

      /* FOOTER */
      .footer {
        padding: 40px 0;
        border-top: 1px solid var(--border-s);
      }
      .footer img {
        opacity: 0.6;
        margin-bottom: 12px;
      }
      .footer p {
        font-size: 0.8rem;
        color: var(--muted);
      }

      @media (max-width: 640px) {
        .container { padding: 0 20px; }
        .section { padding: 72px 0; }
        .hero { padding: 140px 0 80px; }
      }
    </style>
  </body>
</html>
