        font-weight: 700;
      }
      .pillar-icon {
        font-size: 14px;
        color: var(--fg-dim);
        font-weight: 600;
        margin-bottom: 16px;
      }
      .pillar-title {
        font-size: 16px;
        color: var(--fg-muted);
        margin-bottom: 8px;
      }
      .pillar-value {
        font-size: 48px;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 16px;
      }
      .pillar-featured .pillar-value {
        color: var(--accent);
      }
      .pillar-desc {
        color: var(--fg-muted);
        font-size: 14px;
        line-height: 1.6;
      }

      /* === SCOPE === */
      .scope-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }
      @media (max-width: 900px) {
        .scope-grid { grid-template-columns: 1fr; }
      }
      .scope-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
      }
      .scope-in { border-color: var(--accent); }
      .scope-out { border-color: var(--border-strong); }
      .scope-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 24px;
      }
      .scope-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-weight: 700;
      }
      .scope-icon-in {
        background: var(--accent);
        color: #000;
      }
      .scope-icon-out {
        background: var(--border-strong);
        color: var(--fg-muted);
      }
      .scope-card ul {
        list-style: none;
      }
      .scope-card li {
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        color: var(--fg);
      }
      .scope-card li:last-child {
        border-bottom: 0;
      }
      .scope-note {
        margin-top: 24px;
        padding: 16px;
        background: var(--bg-elevated);
        border-radius: var(--radius);
        font-size: 14px;
        color: var(--fg-muted);
        font-style: italic;
      }

      /* === CALCULADORA === */
      .calculator {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
        margin-top: 48px;
      }
      @media (max-width: 900px) {
        .calculator { grid-template-columns: 1fr; }
      }
      .calc-input {
        margin-bottom: 32px;
      }
      .calc-input:last-child {
        margin-bottom: 0;
      }
      .calc-input label {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 14px;
        color: var(--fg-muted);
      }
      .calc-input label strong {
        color: var(--accent);
        font-size: 18px;
        font-weight: 700;
      }
      .calc-input input[type="range"] {
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        height: 4px;
        background: var(--border-strong);
        border-radius: 2px;
        outline: none;
      }
      .calc-input input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--accent);
        cursor: pointer;
        box-shadow: 0 0 0 4px var(--accent-ring);
      }
      .calc-input input[type="range"]::-moz-range-thumb {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--accent);
        cursor: pointer;
        border: 0;
      }
      .calc-hint {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
        font-size: 11px;
        color: var(--fg-dim);
      }
      .calculator-outputs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .calc-output {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
      }
      .calc-output-highlight {
        grid-column: span 2;
        border-color: var(--accent);
        background: var(--accent-bg);
      }
      .calc-output-label {
        font-size: 12px;
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 8px;
      }
      .calc-output-value {
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .calc-output-highlight .calc-output-value {
        color: var(--accent);
        font-size: 32px;
      }

      /* === TIMELINE === */
      .timeline {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
      }
      .timeline-item {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius);
        padding: 24px;
      }
      .timeline-week {
        font-size: 12px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
        font-weight: 600;
      }
      .timeline-item h4 {
        font-size: 18px;
        margin-bottom: 8px;
      }
      .timeline-item p {
        color: var(--fg-muted);
        font-size: 14px;
      }

      /* === COST TABLE === */
      .cost-table {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-bottom: 24px;
      }
      .cost-row {
        display: flex;
        justify-content: space-between;
        padding: 20px 32px;
        border-bottom: 1px solid var(--border);
      }
      .cost-row:last-child { border-bottom: 0; }
      .cost-row-total {
        background: var(--bg-elevated);
        font-size: 18px;
      }
      .margin-note {
        padding: 24px;
        background: var(--accent-bg);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius);
        color: var(--fg);
      }

      /* === PARTS GRID === */
      .parts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }
      @media (max-width: 900px) {
        .parts-grid { grid-template-columns: 1fr; }
      }
      .part-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
      }
      .part-card-featured {
        border-color: var(--accent);
        box-shadow: var(--shadow-glow);
      }
      .part-label {
        font-size: 12px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
        font-weight: 600;
      }
      .part-card h3 {
        font-size: 24px;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
      }
      .part-card ul {
        list-style: none;
      }
      .part-card li {
        padding: 10px 0;
        padding-left: 24px;
        position: relative;
        border-bottom: 1px solid var(--border);
        font-size: 15px;
      }
      .part-card li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--accent);
      }
      .part-card li:last-child {
        border-bottom: 0;
      }

      /* === CLAUSES === */
      .clauses {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
      }
      .clause {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
      }
      .clause h4 {
        font-size: 16px;
        margin-bottom: 8px;
        color: var(--accent);
      }
      .clause p {
        color: var(--fg-muted);
        font-size: 14px;
        line-height: 1.6;
      }

      /* === CTA FINAL === */
      .section-cta {
        background: var(--bg-alt);
        text-align: center;
        padding: 140px 0;
      }
      .cta-title {
        font-size: clamp(48px, 8vw, 96px);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 32px;
      }
      .cta-lead {
        font-size: 18px;
        color: var(--fg-muted);
        max-width: 560px;
        margin: 0 auto 48px;
      }
      .cta-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
      }

      /* === FOOTER === */
      .footer {
        padding: 48px 0;
        border-top: 1px solid var(--border);
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
      }
      .footer-meta {
        color: var(--fg-muted);
        font-size: 13px;
        text-align: right;
      }

      /* === RESPONSIVE === */
      @media (max-width: 640px) {
        .section { padding: 64px 0; }
        .hero { padding: 48px 0 80px; }
        .hero-numbers { padding: 24px; }
        .pillars, .calculator { gap: 16px; }
      }
    </style>
  </body>
</html>
