---
/*
 * NEURONEX — Proposta de Parceria Estratégica
 *
 * Rota: src/pages/p/neuronex-x-parceria.astro
 * URL:  https://lp-neuronex.vercel.app/p/neuronex-x-parceria
 *
 * Customização rápida (procure por /** CUSTOMIZE */):
 *   - Nome dos sócios
 *   - Nome do curso
 *   - Número do WhatsApp
 *   - Token de acesso (opcional)
 *
 * Proteção de link: adicione ?t=SEU_TOKEN na URL. A página valida
 * client-side e redireciona pra / se o token não bater.
 */

/** CUSTOMIZE: dados da proposta */
const proposta = {
  cliente: {
    nome: "Nome dos Sócios",
    curso: "Curso de Amazon",
    alunos: 150,
  },
  whatsapp: "5511968141852",
  token: "af2026",
  numeros: {
    investimento: "10.000",
    equity: "30%",
    prazo: "4 a 6 semanas",
    ticketMedio: 150,
    custoOperacional: 825,
  },
};

const whatsappMsg = encodeURIComponent(
  `Olá! Acabei de ler a proposta da NeuroNex e gostaria de conversar.`
);
const whatsappUrl = `https://wa.me/${proposta.whatsapp}?text=${whatsappMsg}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>NeuroNex × {proposta.cliente.nome} — Proposta de Parceria</title>
    <meta
      name="description"
      content="Proposta de parceria estratégica para desenvolvimento da plataforma de análise Amazon."
    />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body data-token={proposta.token}>
    <!-- ============ BG GLOW DECORATIVOS ============ -->
    <div class="bg-glow bg-glow-1"></div>
    <div class="bg-glow bg-glow-2"></div>

    <!-- ============ NAV ============ -->
    <nav class="nav">
      <div class="container nav-inner">
        <div class="logo">
          <span class="logo-mark">N</span>
          <span class="logo-text">NeuroNex</span>
        </div>
        <a href={whatsappUrl} class="btn btn-ghost" target="_blank" rel="noopener">
          Falar agora
        </a>
      </div>
    </nav>

    <!-- ============ HERO ============ -->
    <section class="section hero">
      <div class="container">
        <div class="badge">
          <span class="badge-dot"></span>
          Proposta confidencial · {new Date().toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' })}
        </div>

        <h1 class="hero-title">
          Parceria Estratégica<br />
          <span class="text-gradient">NeuroNex × {proposta.cliente.nome}</span>
        </h1>

        <p class="hero-subtitle">
          Tecnologia sob medida para construir, lançar e manter a plataforma de
          análise Amazon do seu negócio.
        </p>

        <div class="hero-numbers">
          <div class="hero-number">
            <div class="hero-number-label">Investimento técnico</div>
            <div class="hero-number-value">R$ {proposta.numeros.investimento}</div>
          </div>
          <div class="hero-divider"></div>
          <div class="hero-number">
            <div class="hero-number-label">Participação societária</div>
            <div class="hero-number-value">{proposta.numeros.equity}</div>
          </div>
          <div class="hero-divider"></div>
          <div class="hero-number">
            <div class="hero-number-label">Manutenção contínua</div>
            <div class="hero-number-value">Inclusa</div>
          </div>
        </div>

        <div class="hero-ctas">
          <a href={whatsappUrl} class="btn btn-primary" target="_blank" rel="noopener">
            Agendar conversa
          </a>
          <a href="#proposta" class="btn btn-ghost">Ver proposta completa ↓</a>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 1 — CREDIBILIDADE ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">Quem somos</div>
        <h2 class="section-title">
          Você não está contratando<br />
          <span class="text-muted">um desenvolvedor avulso.</span>
        </h2>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value" data-count="50">+50</div>
            <div class="stat-label">Projetos entregues</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" data-count="98">98%</div>
            <div class="stat-label">Satisfação dos clientes</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" data-count="8">+8</div>
            <div class="stat-label">Anos de mercado</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">24/7</div>
            <div class="stat-label">Suporte dedicado</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">6h</div>
            <div class="stat-label">Resposta média</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">100%</div>
            <div class="stat-label">Sob medida</div>
          </div>
        </div>

        <p class="section-lead">
          A NeuroNex é uma empresa de tecnologia com mais de oito anos
          construindo soluções sob medida para empresas que querem crescer.
          Entregamos sistemas, agentes de IA, landing pages e integrações com
          qualidade de agência e compromisso de parceiro de longo prazo.
        </p>
      </div>
    </section>

    <!-- ============ SEÇÃO 2 — O PRODUTO ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">O produto</div>
        <h2 class="section-title">
          Plataforma completa de<br />
          <span class="text-gradient">análise Amazon.</span>
        </h2>

        <div class="grid-2">
          <ul class="feature-list">
            <li>Extensão Chrome integrada à Amazon Brasil</li>
            <li>Projeção de vendas mensais e faturamento estimado</li>
            <li>Calculadora de lucro com modelos FBA, DBA e OnSite</li>
            <li>Lucro, margem e ROI calculados em tempo real</li>
            <li>Histórico de preço, BSR e Buy Box (30, 90 e 365 dias)</li>
            <li>Análise de concorrentes (FBA vs FBM, rating e preço)</li>
            <li>Campeão do Buy Box com percentual de participação</li>
            <li>Assistente de IA para mentoria personalizada</li>
            <li>Sistema de favoritos e alertas de preço</li>
            <li>Cache próprio com performance alta e custo baixo</li>
          </ul>

          <!-- PREVIEW / IFRAME EMBED -->
          <div class="preview-wrap">
            <div class="preview-frame">
              <div class="preview-bar">
                <span class="dot dot-red"></span>
                <span class="dot dot-yellow"></span>
                <span class="dot dot-green"></span>
                <span class="preview-url">amazon.com.br/dp/B0B1N25YY5</span>
              </div>
              <!--
                CUSTOMIZE: trocar src pelo URL do protótipo/demo
                Pode ser um vídeo Loom embeddado, um screenshot animado,
                ou um iframe real do protótipo hospedado.

                Exemplos:
                  <iframe src="https://www.loom.com/embed/SEU_VIDEO_ID" ...></iframe>
                  <iframe src="https://protótipo.neuronex.digital" ...></iframe>
              -->
              <div class="preview-content">
                <div class="preview-placeholder">
                  <div class="preview-icon">▶</div>
                  <div>Demo da extensão em funcionamento</div>
                  <div class="preview-small">Pré-visualização será exibida aqui</div>
                </div>
              </div>
            </div>
            <div class="preview-caption">
              Protótipo ao vivo — extensão rodando em página real da Amazon
            </div>
          </div>
        </div>

        <p class="section-lead">
          O aluno toma decisão de compra de produto em segundos, não em horas.
          Todos os dados críticos num único painel, direto na página do produto
          da Amazon.
        </p>
      </div>
    </section>

    <!-- ============ SEÇÃO 3 — MÉTODO 4 ETAPAS ============ -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Nosso processo</div>
        <h2 class="section-title">
          Método NeuroNex<br />
          <span class="text-muted">aplicado ao seu projeto.</span>
        </h2>

        <div class="steps">
          <div class="step">
            <div class="step-num">01</div>
            <h3 class="step-title">Diagnóstico e Estratégia</h3>
            <p class="step-desc">
              Mapeamento completo de endpoints, fluxos de usuário, fórmulas
              de cálculo e requisitos operacionais. Esta etapa já foi
              concluída: 29 endpoints mapeados, 23 respostas reais capturadas
              e fórmulas validadas.
            </p>
            <div class="step-tag">Etapa concluída</div>
          </div>

          <div class="step">
            <div class="step-num">02</div>
            <h3 class="step-title">Design de Sistema e Arquitetura</h3>
            <p class="step-desc">
              Definição de stack, schema de banco, pontos de integração com
              Keepa e OpenAI, design system visual e fluxos de autenticação.
            </p>
            <div class="step-tag">Etapa concluída</div>
          </div>

          <div class="step">
            <div class="step-num">03</div>
            <h3 class="step-title">Construção e Integração</h3>
            <p class="step-desc">
              Desenvolvimento da extensão Chrome, backend proxy cacheado,
              painel de configurações, testes automatizados, deploy e
              publicação na Chrome Web Store.
            </p>
          </div>

          <div class="step">
            <div class="step-num">04</div>
            <h3 class="step-title">Ativação e Otimização Contínua</h3>
            <p class="step-desc">
              Lançamento para os primeiros alunos, monitoramento em tempo
              real, correções e otimizações baseadas em uso real da
              plataforma.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 4 — STACK ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">Stack profissional</div>
        <h2 class="section-title">
          Tecnologia de ponta,<br />
          <span class="text-muted">sem improviso.</span>
        </h2>

        <div class="stack-grid">
          {[
            "Next.js",
            "NestJS",
            "TypeScript",
            "PostgreSQL",
            "Supabase",
            "Vercel",
            "Railway",
            "OpenAI",
            "Claude",
            "Stripe",
            "GitHub",
            "Sentry",
          ].map((tech) => (
            <div class="stack-item">{tech}</div>
          ))}
        </div>

        <div class="stack-metrics">
          <div class="stack-metric">
            <div class="stack-metric-value">99.9%</div>
            <div class="stack-metric-label">Uptime garantido</div>
          </div>
          <div class="stack-metric">
            <div class="stack-metric-value">+85%</div>
            <div class="stack-metric-label">Cobertura de testes</div>
          </div>
          <div class="stack-metric">
            <div class="stack-metric-value">0</div>
            <div class="stack-metric-label">Incidentes críticos</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 5 — ENGENHARIA REVERSA JÁ FEITA ============ -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Descoberta técnica concluída</div>
        <h2 class="section-title">
          80% do trabalho<br />
          <span class="text-gradient">já está entregue.</span>
        </h2>

        <div class="assets-grid">
          <div class="asset-card">
            <div class="asset-num">29</div>
            <div class="asset-label">Endpoints mapeados</div>
          </div>
          <div class="asset-card">
            <div class="asset-num">23</div>
            <div class="asset-label">Bodies de API capturados</div>
          </div>
          <div class="asset-card">
            <div class="asset-num">100%</div>
            <div class="asset-label">Fórmulas validadas</div>
          </div>
          <div class="asset-card">
            <div class="asset-num">4</div>
            <div class="asset-label">Tabelas de taxas Amazon prontas</div>
          </div>
          <div class="asset-card">
            <div class="asset-num">1</div>
            <div class="asset-label">Schema de banco desenhado</div>
          </div>
          <div class="asset-card">
            <div class="asset-num">60%</div>
            <div class="asset-label">Redução no tempo de dev</div>
          </div>
        </div>

        <p class="section-lead">
          Toda a análise técnica já foi executada pela NeuroNex. Entramos no
          projeto com o caminho crítico pavimentado: zero risco de descoberta,
          estimativa de prazo validada, stack definida.
        </p>
      </div>
    </section>

    <!-- ============ SEÇÃO 6 — VALOR DE MERCADO ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">Valor de mercado</div>
        <h2 class="section-title">
          O que vocês<br />
          <span class="text-gradient">economizam com a NeuroNex.</span>
        </h2>

        <div class="pricing-table">
          <div class="pricing-row">
            <div class="pricing-label">Agência especializada</div>
            <div class="pricing-value pricing-old">R$ 80.000 a R$ 120.000</div>
          </div>
          <div class="pricing-row">
            <div class="pricing-label">Freelancer sênior</div>
            <div class="pricing-value pricing-old">R$ 40.000 a R$ 60.000</div>
          </div>
          <div class="pricing-row">
            <div class="pricing-label">Manutenção mensal externa</div>
            <div class="pricing-value pricing-old">R$ 4.000 a R$ 8.000/mês</div>
          </div>
          <div class="pricing-row pricing-featured">
            <div class="pricing-label">
              <strong>Proposta NeuroNex</strong>
            </div>
            <div class="pricing-value pricing-new">R$ 10.000 único</div>
          </div>
        </div>

        <div class="highlight-box">
          <div class="highlight-num">R$ 50k a R$ 100k</div>
          <div class="highlight-text">
            de economia imediata — o equivalente a um investidor entrando na
            operação sem exigir retorno imediato.
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 7 — A PROPOSTA (PILARES) ============ -->
    <section id="proposta" class="section section-alt">
      <div class="container">
        <div class="section-label">A proposta</div>
        <h2 class="section-title">
          Três pilares da<br />
          <span class="text-gradient">nossa sociedade.</span>
        </h2>

        <div class="pillars">
          <div class="pillar">
            <div class="pillar-icon">01</div>
            <div class="pillar-title">Investimento técnico</div>
            <div class="pillar-value">R$ 10.000</div>
            <p class="pillar-desc">
              Pagos em 3 parcelas durante a execução do MVP. 40% na
              assinatura, 30% no marco intermediário, 30% na entrega final.
            </p>
          </div>

          <div class="pillar pillar-featured">
            <div class="pillar-badge">Principal</div>
            <div class="pillar-icon">02</div>
            <div class="pillar-title">Participação societária</div>
            <div class="pillar-value">30%</div>
            <p class="pillar-desc">
              Equity da NeuroNex na nova empresa, com vesting de 4 anos e
              cliff de 1 ano. Padrão de mercado para cofundador técnico
              único.
            </p>
          </div>

          <div class="pillar">
            <div class="pillar-icon">03</div>
            <div class="pillar-title">Manutenção contínua</div>
            <div class="pillar-value">Inclusa</div>
            <p class="pillar-desc">
              Correções, atualizações e manutenção técnica inclusas enquanto
              a sociedade existir. Sem cobrança por hora, sem contrato
              paralelo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 8 — INCLUÍDO vs FORA ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">Escopo detalhado</div>
        <h2 class="section-title">
          O que está incluído<br />
          <span class="text-muted">e o que fica fora.</span>
        </h2>

        <div class="scope-grid">
          <div class="scope-card scope-in">
            <div class="scope-title">
              <span class="scope-icon scope-icon-in">✓</span>
              Incluído sem custo adicional
            </div>
            <ul>
              <li>Correção de bugs e falhas do sistema</li>
              <li>Atualizações de compatibilidade com Amazon e Keepa</li>
              <li>Ajustes de performance e otimizações</li>
              <li>Atualização de dependências e patches de segurança</li>
              <li>Manutenção de infraestrutura e monitoramento 24/7</li>
              <li>Suporte técnico interno para os sócios</li>
              <li>Pequenos ajustes de interface solicitados pela operação</li>
            </ul>
          </div>

          <div class="scope-card scope-out">
            <div class="scope-title">
              <span class="scope-icon scope-icon-out">→</span>
              Projetos novos (negociados em separado)
            </div>
            <ul>
              <li>Aplicativos mobile iOS e Android</li>
              <li>Expansão para outros marketplaces (Mercado Livre, Shopee)</li>
              <li>Sistemas adicionais (CRM, ERP, automações complexas)</li>
              <li>Migrações arquiteturais por mudança de modelo de negócio</li>
            </ul>
            <div class="scope-note">
              A NeuroNex segue como fornecedor técnico natural, com desconto
              de parceria em todos os novos projetos.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 9 — CALCULADORA ROI INTERATIVA ============ -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Simulador de retorno</div>
        <h2 class="section-title">
          Veja o potencial<br />
          <span class="text-gradient">em números reais.</span>
        </h2>

        <p class="section-lead">
          Ajuste os sliders abaixo com as suas premissas. A calculadora projeta
          receita mensal, parte de cada sócio e breakeven do investimento.
        </p>

        <div class="calculator">
          <div class="calculator-inputs">
            <div class="calc-input">
              <label>
                Taxa de conversão dos {proposta.cliente.alunos} alunos
                <strong id="out-conversao">30%</strong>
              </label>
              <input
                type="range"
                id="conv"
                min="5"
                max="100"
                value="30"
                step="5"
              />
              <div class="calc-hint">
                <span>5%</span>
                <span>100%</span>
              </div>
            </div>

            <div class="calc-input">
              <label>
                Ticket mensal por cliente
                <strong id="out-ticket">R$ 150</strong>
              </label>
              <input
                type="range"
                id="ticket"
                min="50"
                max="500"
                value="150"
                step="10"
              />
              <div class="calc-hint">
                <span>R$ 50</span>
                <span>R$ 500</span>
              </div>
            </div>

            <div class="calc-input">
              <label>
                Meses de projeção
                <strong id="out-meses">12 meses</strong>
              </label>
              <input
                type="range"
                id="meses"
                min="3"
                max="36"
                value="12"
                step="3"
              />
              <div class="calc-hint">
                <span>3 meses</span>
                <span>36 meses</span>
              </div>
            </div>
          </div>

          <div class="calculator-outputs">
            <div class="calc-output">
              <div class="calc-output-label">Clientes ativos</div>
              <div class="calc-output-value" id="out-clientes">45</div>
            </div>

            <div class="calc-output">
              <div class="calc-output-label">Receita mensal</div>
              <div class="calc-output-value" id="out-mrr">R$ 6.750</div>
            </div>

            <div class="calc-output">
              <div class="calc-output-label">Lucro mensal (após custos)</div>
              <div class="calc-output-value" id="out-lucro">R$ 5.925</div>
            </div>

            <div class="calc-output calc-output-highlight">
              <div class="calc-output-label">Receita total no período</div>
              <div class="calc-output-value" id="out-total">R$ 81.000</div>
            </div>

            <div class="calc-output">
              <div class="calc-output-label">Parte NeuroNex (30%)</div>
              <div class="calc-output-value" id="out-neuronex">R$ 21.330</div>
            </div>

            <div class="calc-output">
              <div class="calc-output-label">Parte de cada sócio (35%)</div>
              <div class="calc-output-value" id="out-socio">R$ 24.885</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 10 — CRONOGRAMA ============ -->
    <section class="section">
      <div class="container">
        <div class="section-label">Cronograma</div>
        <h2 class="section-title">
          Plataforma no ar em<br />
          <span class="text-gradient">{proposta.numeros.prazo}.</span>
        </h2>

        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-week">Semanas 1-2</div>
            <h4>Sprint 1 · Fundação</h4>
            <p>Backend, auth, banco de dados, tabelas de taxas, OAuth.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-week">Semana 3</div>
            <h4>Sprint 2 · Integração</h4>
            <p>Keepa API, proxy cacheado, endpoints de histórico e Buy Box.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-week">Semanas 4-5</div>
            <h4>Sprint 3 · Interface</h4>
            <p>Extensão Chrome, análises, calculadora, gráficos.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-week">Semana 6</div>
            <h4>Sprint 4 · Lançamento</h4>
            <p>Assistente de IA, alertas, Chrome Web Store, landing page.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEÇÃO 11 — CUSTOS OPERACIONAIS ============ -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Operação</div>
        <h2 class="section-title">
          Estrutura enxuta,<br />
          <span class="text-gradient">margem alta.</span>
        </h2>

        <div class="cost-table">
          <div class="cost-row">
            <span>Keepa API Pro</span>
            <span>R$ 275/mês</span>
          </div>
          <div class="cost-row">
            <span>Infraestrutura (servidor, banco, cache)</span>
            <span>R$ 150/mês</span>
          </div>
          <div class="cost-row">
            <span>OpenAI / Claude (assistente de IA)</span>
