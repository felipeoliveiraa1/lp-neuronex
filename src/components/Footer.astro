---
import { site, footer } from '../data/site';
---

<footer style="position:relative">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="nav-logo" href="#hero" style="margin-bottom:0" aria-label={site.brand}>
          <img src="/logo-nav.webp" alt={site.brand} width="140" height="40" />
        </a>
        <p>{footer.tagline}</p>
      </div>

      {footer.columns.map((col) => (
        <div>
          <p class="footer-col-title">{col.title}</p>
          <ul class="footer-links">
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {site.year} {site.brand}. Todos os direitos reservados.</span>
      <div class="footer-socials">
        <a class="social-link" href={site.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <span class="iconify" data-icon="lucide:linkedin"></span>
        </a>
        <a class="social-link" href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
          <span class="iconify" data-icon="lucide:instagram"></span>
        </a>
        <a class="social-link" href={site.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
          <span class="iconify" data-icon="lucide:message-circle"></span>
        </a>
        <a class="social-link" href={site.social.github} target="_blank" rel="noopener" aria-label="GitHub">
          <span class="iconify" data-icon="lucide:github"></span>
        </a>
      </div>
    </div>
  </div>
</footer>
